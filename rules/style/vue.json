{
  "rules": {
    "vue/define-emits-declaration": ["error"],
    "vue/define-props-declaration": ["error", "runtime"],
    "vue/define-props-destructuring": [
      "error",
      {
        "destructure": "never"
      }
    ],
    "vue/require-typed-ref": ["error"],
    "vue/component-definition-name-casing": ["error"]
  }
}
